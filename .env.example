# Ankr Solana HTTP endpoints (dynamically constructed from ANKR_API_KEY)
# Format: https://solana-mainnet.g.alchemy.com/v2/{ANKR_API_KEY}
# Fallback: https://api.mainnet-beta.solana.com
SOLANA_RPC_HTTP_PRIMARY=ankr
SOLANA_RPC_HTTP_BACKUP_1=https://api.mainnet-beta.solana.com
# Ankr Solana WebSocket endpoint (optional, for account/signature subscriptions)
# Format: wss://solana-mainnet.g.alchemy.com/v2/{ANKR_API_KEY}
SOLANA_RPC_WS_PRIMARY=
SOLANA_RPC_WS_BACKUP_1=

# Jito Configuration (Execution Provider)
