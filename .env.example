# Environment Configuration for Solana Meme Trading Bot
# Copy this to .env and fill in your values
APP_ENV=development
SQLITE_PATH=./data/trading_bot.sqlite3

# CRITICAL SAFETY SETTINGS - Always review before enabling live trading
DRY_RUN=true
LIVE_TRADING_ENABLED=false
SIMULATION_ENABLED=true

# Provider Mode: mock / online_readonly / live
PROVIDER_MODE=mock

# GMGN API Configuration (Market Data Provider)
GMGN_API_BASE_URL=https://api.gmgn.ai
# Add your keys (dynamic numbering: GMGN_API_KEY_1, _2, ... _N)
GMGN_API_KEY_1=
GMGN_PUBLIC_KEY_1=
GMGN_PRIVATE_KEY_1=
# GMGN_API_KEY_2=
# GMGN_API_KEY_3=
# ... add as many as needed

# Jupiter API Configuration (Swap Provider)
JUPITER_API_BASE_URL=https://quote-api.jup.ag
# Add your keys (dynamic numbering: JUPITER_API_KEY_1, _2, ... _N)
JUPITER_API_KEY_1=
# JUPITER_API_KEY_2=
# ... add as many as needed

# Ankr RPC Configuration (RPC Provider)
# Add your keys (dynamic numbering: ANKR_API_KEY_1, _2, ... _N)
ANKR_API_KEY_1=
# ANKR_API_KEY_2=
# ... add as many as needed

# Solana RPC endpoints (fallback when no Ankr keys)
SOLANA_RPC_HTTP_PRIMARY=https://api.mainnet-beta.solana.com
SOLANA_RPC_HTTP_BACKUP_1=
SOLANA_RPC_WS_PRIMARY=
SOLANA_RPC_WS_BACKUP_1=

# Jito Configuration (Execution Provider)
JITO_ENABLED=true
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_TIP_FLOOR_URL=https://bundles.jito.wtf/api/v1/bundles/tip_floor
JITO_TIP_STREAM_WS=wss://bundles.jito.wtf/api/v1/bundles/tip_stream

# Wallet Configuration (ONLY needed for LIVE_TRADING_ENABLED=true)
# NEVER commit real private keys to repository
WALLET_PUBLIC_KEY=
WALLET_PRIVATE_KEY_BASE58=

# Trading Parameters (Optional - defaults in code)
POLL_INTERVAL_SECONDS=60
ACTIVE_POSITION_PRICE_POLL_SECONDS=1
TIP_FLOOR_REFRESH_SECONDS=3

BUY_SLIPPAGE_CAP_BPS=1500
SELL_SLIPPAGE_CAP_BPS=2000
EMERGENCY_SLIPPAGE_CAP_BPS=3500
PRICE_IMPACT_HARD_CAP_PCT=10

LIVE_ROLLING_10_LOSS_LIMIT=-0.20
MAX_REQUOTE_RETRY=2

# Risk Feature Scan Tiers (dynamic based on remaining position value in SOL)
RISK_FEATURE_SCAN_TIER_1_SOL=1.5
RISK_FEATURE_SCAN_TIER_1_SECONDS=2
RISK_FEATURE_SCAN_TIER_2_SOL=1.0
RISK_FEATURE_SCAN_TIER_2_SECONDS=4
RISK_FEATURE_SCAN_TIER_3_SOL=0.5
RISK_FEATURE_SCAN_TIER_3_SECONDS=8
RISK_FEATURE_SCAN_TIER_4_SOL=0.25
RISK_FEATURE_SCAN_TIER_4_SECONDS=16
RISK_FEATURE_SCAN_TIER_5_SECONDS=32

# Dust Position Rules (in SOL, not USD)
DUST_FORCE_EXIT_SOL=0.125
